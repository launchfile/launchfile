# yaml-language-server: $schema=https://launchfile.dev/schema/v1
version: launch/v1
name: umami
description: "Simple, fast, privacy-focused web analytics"
repository: https://github.com/umami-software/umami
logo: https://raw.githubusercontent.com/umami-software/umami/master/src/assets/logo.svg

image: ghcr.io/umami-software/umami:postgresql-latest
provides:
  - protocol: http
    port: 3000
    exposed: true
requires:
  - type: postgres
    set_env:
      DATABASE_URL: $url
env:
  APP_SECRET:
    generator: secret
    sensitive: true
    description: "Random string used to generate unique values"
health: /api/heartbeat
restart: always
