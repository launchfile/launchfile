# yaml-language-server: $schema=https://launchfile.dev/schema/v1
version: launch/v1
name: mattermost
description: "Open-source team messaging and collaboration"

image: mattermost/mattermost-team-edition:latest
provides:
  - protocol: http
    port: 8065
    exposed: true
requires:
  - type: postgres
    set_env:
      MM_SQLSETTINGS_DATASOURCE: $url
env:
  MM_SERVICESETTINGS_SITEURL:
    required: true
    description: "Public URL for the Mattermost instance"
storage:
  data:
    path: /mattermost/data
    persistent: true
  logs:
    path: /mattermost/logs
    persistent: true
  config:
    path: /mattermost/config
    persistent: true
  plugins:
    path: /mattermost/plugins
    persistent: true
health:
  path: /api/v4/system/ping
  start_period: 30s
restart: always
