{
  "name": "@launchfile/macos-dev",
  "version": "0.1.4",
  "description": "macOS dev provider for Launchfile — run apps locally via brew services and native runtimes",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "dev": "bun run src/cli.ts"
  },
  "keywords": [
    "launchfile",
    "macos",
    "dev",
    "provider",
    "brew"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/launchfile/launchfile",
    "directory": "providers/macos-dev"
  },
  "dependencies": {
    "@launchfile/sdk": "^0.1.4",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "@types/semver": "^7.7.1",
    "typescript": "^6.0.0",
    "vitest": "^4.1.3"
  }
}
