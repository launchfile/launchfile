{
  "name": "@launchfile/aws",
  "version": "0.1.0",
  "description": "AWS provider for Launchfile — translate a Launchfile into Terraform (EC2 + RDS + ALB). Translation-only conformance probe; never applies.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "launchfile-aws": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "dev": "bun run src/cli.ts",
    "conformance": "bun run src/conformance.ts",
    "validate:tf": "bun run src/validate-tf.ts"
  },
  "keywords": [
    "launchfile",
    "aws",
    "terraform",
    "provider",
    "iac"
  ],
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md"
  ],
  "license": "MIT",
  "publishConfig": {
    "tag": "alpha"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/launchfile/launchfile.git",
    "directory": "providers/aws"
  },
  "dependencies": {
    "@launchfile/sdk": "^0.2.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.0",
    "vitest": "^4.1.3"
  }
}
