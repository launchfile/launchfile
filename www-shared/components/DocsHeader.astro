---
interface Props {
  site?: "dev" | "org" | "io";
}

const siteLabels: Record<string, string> = {
  dev: "Docs",
  org: "Spec",
  io: "Catalog",
};

const { site = "dev" } = Astro.props;
const siteLabel = siteLabels[site] ?? "Docs";

const sites = [
  { key: "dev", label: "Docs", href: "https://launchfile.dev" },
  { key: "org", label: "Spec", href: "https://launchfile.org" },
  { key: "io", label: "Catalog", href: "https://launchfile.io" },
] as const;

const hasDrawerNav = Astro.slots.has("drawer-nav");
---

<header class="docs-header">
  <div class="docs-header-inner">
    <div class="docs-header-left">
      <button
        id="menu-toggle"
        class="docs-menu-toggle"
        aria-label="Open navigation"
        aria-expanded="false"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M3 5h14M3 10h14M3 15h14" />
        </svg>
      </button>

      <a href="/" class="docs-logo" aria-label={`Launchfile ${siteLabel} home`}>
        <img src="/favicon.svg" alt="" height="20" width="20" />
        <span class="logo-text">Launchfile</span>
        <span class="logo-divider"></span>
        <span class="logo-identifier">{siteLabel}</span>
      </a>
    </div>

    <button class="docs-search" type="button" aria-label="Search documentation">
      <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <circle cx="8.5" cy="8.5" r="5.5" />
        <path d="M13 13l4 4" />
      </svg>
      <span class="docs-search-text">Search docs...</span>
      <kbd class="docs-search-kbd"><span>⌘</span>K</kbd>
    </button>

    <div class="docs-header-right">
      <nav class="docs-site-tabs" aria-label="Sites">
        {sites.map((s) => (
          <a
            href={s.key === site ? "/" : s.href}
            class:list={["docs-site-tab", { active: s.key === site }]}
            aria-current={s.key === site ? "true" : undefined}
          >
            {s.label}
          </a>
        ))}
      </nav>

      <a href="https://launchfile.io/get-started" class="docs-get-started">Get Started</a>

      <button class="docs-search-icon" type="button" aria-label="Search documentation">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <circle cx="8.5" cy="8.5" r="5.5" />
          <path d="M13 13l4 4" />
        </svg>
      </button>

      <div class="docs-header-divider" aria-hidden="true"></div>

      <a
        href="https://github.com/launchfile/launchfile"
        class="docs-header-icon"
        aria-label="GitHub"
        target="_blank"
        rel="noopener"
      >
        <svg viewBox="0 0 20 20" fill="currentColor" width="20" height="20" aria-hidden="true">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M10 1.667c-4.605 0-8.334 3.823-8.334 8.544 0 3.78 2.385 6.974 5.698 8.106.417.075.573-.182.573-.406 0-.203-.011-.875-.011-1.592-2.093.397-2.635-.522-2.802-1.002-.094-.246-.5-1.005-.854-1.207-.291-.16-.708-.556-.01-.567.656-.01 1.124.62 1.281.876.75 1.292 1.948.93 2.427.705.073-.555.291-.93.531-1.143-1.854-.213-3.791-.95-3.791-4.218 0-.929.322-1.698.854-2.296-.083-.214-.375-1.09.083-2.265 0 0 .698-.224 2.292.876a7.576 7.576 0 0 1 2.083-.288c.709 0 1.417.096 2.084.288 1.593-1.11 2.291-.875 2.291-.875.459 1.174.167 2.05.084 2.263.53.599.854 1.357.854 2.297 0 3.278-1.948 4.005-3.802 4.219.302.266.563.78.563 1.58 0 1.143-.011 2.061-.011 2.35 0 .224.156.491.573.405a8.365 8.365 0 0 0 4.11-3.116 8.707 8.707 0 0 0 1.567-4.99c0-4.721-3.73-8.545-8.334-8.545Z" />
        </svg>
      </a>
    </div>
  </div>
</header>

<!-- Mobile drawer: slides from left below the sticky header -->
<dialog id="sidebar-drawer" class="sidebar-drawer" aria-label="Navigation">
  <div class="sidebar-drawer-panel">
    <nav class="drawer-site-tabs" aria-label="Sites">
      {sites.map((s) => (
        <a
          href={s.key === site ? "/" : s.href}
          class:list={["drawer-site-tab", { active: s.key === site }]}
          aria-current={s.key === site ? "true" : undefined}
        >
          {s.label}
        </a>
      ))}
      <a href="https://launchfile.io/get-started" class="drawer-get-started">Get Started</a>
    </nav>

    {hasDrawerNav && <hr class="drawer-divider" />}
    {hasDrawerNav && <slot name="drawer-nav" />}
  </div>
</dialog>

<script>
  // Hamburger + drawer toggle: self-contained with the header component.
  // Uses astro:page-load for View Transitions compatibility.
  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById("menu-toggle");
    const drawer = document.getElementById("sidebar-drawer") as HTMLDialogElement | null;
    if (!toggle || !drawer) return;

    const HAMBURGER_PATH = "M3 5h14M3 10h14M3 15h14";
    const CLOSE_PATH = "M5 5l10 10M15 5L5 15";

    function setIcon(isOpen: boolean) {
      const path = toggle!.querySelector("path");
      if (path) path.setAttribute("d", isOpen ? CLOSE_PATH : HAMBURGER_PATH);
      toggle!.setAttribute("aria-expanded", String(isOpen));
      toggle!.setAttribute("aria-label", isOpen ? "Close navigation" : "Open navigation");
    }

    toggle.addEventListener("click", () => {
      if (drawer.open) {
        closeDrawer();
      } else {
        drawer.showModal();
        setIcon(true);
        requestAnimationFrame(() => drawer.classList.add("open"));
      }
    });

    const closeDrawer = () => {
      drawer.classList.remove("open");
      setIcon(false);
      setTimeout(() => drawer.close(), 400);
    };

    drawer.addEventListener("click", (e) => {
      if (e.target === drawer) closeDrawer();
    });

    // Animate out on ESC instead of snap-closing
    drawer.addEventListener("cancel", (e) => {
      e.preventDefault();
      closeDrawer();
    });

    drawer.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeDrawer);
    });
  });
</script>
