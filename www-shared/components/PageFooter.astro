---
import { getPrevPage, getNextPage } from "@/lib/navigation";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const prev = getPrevPage(currentPath);
const next = getNextPage(currentPath);
---

{(prev || next) && (
  <nav class="page-footer" aria-label="Pagination">
    {prev ? (
      <a href={prev.href} class="page-footer-link prev">
        <span class="page-footer-label">Previous</span>
        <span class="page-footer-title">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M10 3L5 8l5 5" />
          </svg>
          {prev.title}
        </span>
      </a>
    ) : <div />}
    {next ? (
      <a href={next.href} class="page-footer-link next">
        <span class="page-footer-label">Next</span>
        <span class="page-footer-title">
          {next.title}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M6 3l5 5-5 5" />
          </svg>
        </span>
      </a>
    ) : <div />}
  </nav>
)}
