{
  "name": "launchfile",
  "version": "0.2.0",
  "description": "Launchfile CLI — describe your app, deploy it anywhere",
  "type": "module",
  "bin": {
    "launchfile": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "dev": "bun run src/cli.ts"
  },
  "keywords": [
    "launchfile",
    "deploy",
    "docker",
    "cli"
  ],
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/launchfile/launchfile.git",
    "directory": "packages/launchfile"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@launchfile/sdk": "^0.2.0",
    "@launchfile/docker": "^0.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  }
}
