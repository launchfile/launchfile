{
  "name": "@launchfile/sdk",
  "version": "0.1.2",
  "description": "TypeScript SDK for parsing, validating, and serializing Launchfiles",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": "./dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "schema/**",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && mkdir -p schema && cp ../spec/schema/launchfile.schema.json schema/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/"
  },
  "keywords": [
    "launchfile",
    "app-descriptor",
    "deployment",
    "yaml",
    "devops"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/launchfile/launchfile.git",
    "directory": "sdk"
  },
  "dependencies": {
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.0",
    "vitest": "^4.1.3"
  }
}
