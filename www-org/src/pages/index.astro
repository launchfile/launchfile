---
import Base from "@shared/layouts/Base.astro";
import DocsHeader from "@shared/components/DocsHeader.astro";
import SearchDialog from "@shared/components/SearchDialog.astro";

import "@/styles/global.css";

const guides = [
  { title: "Why Launchfile", href: "/why/", desc: "The origin, hypothesis, and landscape behind the specification." },
  { title: "Quick Start", href: "/spec/quick-start/", desc: "Three fields to a running app. Learn the basics in two minutes." },
  { title: "Expression Syntax", href: "/spec/expression-syntax/", desc: "Wire dynamic values between resources, components, and secrets." },
  { title: "Value Patterns", href: "/spec/value-patterns/", desc: "Scalar shorthands that expand into structured objects." },
  { title: "Design Principles", href: "/design/", desc: "Why the spec is shaped this way — 13 principles and key decisions." },
];

const specSections = [
  { title: "Components", href: "/spec/components/", icon: "grid", desc: "Multi-component apps with provides, requires, and dependency wiring." },
  { title: "Requires", href: "/spec/requires/", icon: "link", desc: "Declare resource dependencies — postgres, redis, s3, and more." },
  { title: "Environment", href: "/spec/env/", icon: "key", desc: "Typed env vars with defaults, generators, and sensitivity flags." },
  { title: "Commands", href: "/spec/commands/", icon: "terminal", desc: "Lifecycle stages: build, release, start, seed, test, and custom." },
];
---

<Base title="Launchfile — Application Deployment Specification" description="An open specification for describing application deployment requirements. Platform-agnostic, human-writable, machine-parseable." site="org">
  <DocsHeader slot="nav" site="org" />

  <main>
    <!-- Hero section with grid pattern background -->
    <div class="hero-section">
      <div class="hero-grid-pattern" aria-hidden="true"></div>
      <div class="hero-gradient" aria-hidden="true"></div>
      <div class="hero-content">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          Specification v1
        </div>
        <h1 class="hero-title">
          The Launchfile Specification
        </h1>
        <p class="hero-subtitle">
          Describe <em>what</em> your app needs — not <em>how</em> to build the infrastructure. One file. Any platform.
        </p>
        <div class="hero-actions">
          <a href="/spec/" class="hero-btn-primary">
            Read the Spec
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 3l5 5-5 5" /></svg>
          </a>
          <a href="/spec/quick-start/" class="hero-btn-secondary">
            Quick Start
          </a>
        </div>

        <div class="hero-code-block">
          <div class="hero-code-header">
            <div class="hero-code-dots">
              <span></span><span></span><span></span>
            </div>
            <span class="hero-code-filename">Launchfile</span>
          </div>
          <pre><code><span class="hl-key">version</span>: <span class="hl-str">launch/v1</span>
<span class="hl-key">name</span>: <span class="hl-str">my-app</span>
<span class="hl-key">runtime</span>: <span class="hl-str">node</span>
<span class="hl-key">requires</span>: <span class="hl-bracket">[</span><span class="hl-str">postgres</span>, <span class="hl-str">redis</span><span class="hl-bracket">]</span>
<span class="hl-key">commands</span>:
  <span class="hl-key">start</span>: <span class="hl-str">"node server.js"</span>
<span class="hl-key">health</span>: <span class="hl-str">/healthz</span></code></pre>
        </div>
      </div>
    </div>

    <!-- Guides section -->
    <div class="home-section">
      <h2 class="home-section-title">Guides</h2>
      <div class="guides-list">
        {guides.map((guide) => (
          <a href={guide.href} class="guide-item">
            <div>
              <h3 class="guide-title">{guide.title}</h3>
              <p class="guide-desc">{guide.desc}</p>
            </div>
            <svg class="guide-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M6 3l5 5-5 5" /></svg>
          </a>
        ))}
      </div>
    </div>

    <!-- Spec sections as resource cards -->
    <div class="home-section">
      <h2 class="home-section-title">Specification</h2>
      <div class="spec-cards-grid">
        {specSections.map((section) => (
          <a href={section.href} class="spec-card" data-icon={section.icon}>
            <div class="spec-card-pattern" aria-hidden="true"></div>
            <div class="spec-card-icon" aria-hidden="true">
              {section.icon === "grid" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
              )}
              {section.icon === "link" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              )}
              {section.icon === "key" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
              )}
              {section.icon === "terminal" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
              )}
            </div>
            <h3 class="spec-card-title">{section.title}</h3>
            <p class="spec-card-desc">{section.desc}</p>
          </a>
        ))}
      </div>
    </div>

    <!-- All spec fields quick nav -->
    <div class="home-section">
      <h2 class="home-section-title">Reference</h2>
      <div class="ref-grid">
        <a href="/spec/top-level-fields/" class="ref-link">Top-Level Fields</a>
        <a href="/spec/provides/" class="ref-link">Provides</a>
        <a href="/spec/supports/" class="ref-link">Supports</a>
        <a href="/spec/secrets/" class="ref-link">Secrets</a>
        <a href="/spec/health/" class="ref-link">Health</a>
        <a href="/spec/build/" class="ref-link">Build</a>
        <a href="/spec/storage/" class="ref-link">Storage</a>
        <a href="/spec/depends-on/" class="ref-link">Depends On</a>
        <a href="/spec/host/" class="ref-link">Host</a>
        <a href="/spec/other-fields/" class="ref-link">Other Fields</a>
        <a href="/spec/resource-property-vocabulary/" class="ref-link">Resource Properties</a>
        <a href="/spec/yaml-compatibility/" class="ref-link">YAML Compatibility</a>
        <a href="/spec/extensibility/" class="ref-link">Extensibility</a>
      </div>
    </div>

    <!-- Ecosystem -->
    <div class="home-section home-section-last">
      <h2 class="home-section-title">Ecosystem</h2>
      <div class="ecosystem-grid">
        <a href="https://launchfile.dev" class="ecosystem-card">
          <div class="ecosystem-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <h3 class="ecosystem-title">Developer Docs</h3>
          <p class="ecosystem-desc">SDK reference, examples, and getting started guides.</p>
        </a>
        <a href="https://launchfile.io" class="ecosystem-card">
          <div class="ecosystem-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3 class="ecosystem-title">App Catalog</h3>
          <p class="ecosystem-desc">Browse Launchfiles for 50+ open-source apps.</p>
        </a>
        <a href="https://github.com/launchfile/launchfile" class="ecosystem-card">
          <div class="ecosystem-icon">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M10 1.667c-4.605 0-8.334 3.823-8.334 8.544 0 3.78 2.385 6.974 5.698 8.106.417.075.573-.182.573-.406 0-.203-.011-.875-.011-1.592-2.093.397-2.635-.522-2.802-1.002-.094-.246-.5-1.005-.854-1.207-.291-.16-.708-.556-.01-.567.656-.01 1.124.62 1.281.876.75 1.292 1.948.93 2.427.705.073-.555.291-.93.531-1.143-1.854-.213-3.791-.95-3.791-4.218 0-.929.322-1.698.854-2.296-.083-.214-.375-1.09.083-2.265 0 0 .698-.224 2.292.876a7.576 7.576 0 0 1 2.083-.288c.709 0 1.417.096 2.084.288 1.593-1.11 2.291-.875 2.291-.875.459 1.174.167 2.05.084 2.263.53.599.854 1.357.854 2.297 0 3.278-1.948 4.005-3.802 4.219.302.266.563.78.563 1.58 0 1.143-.011 2.061-.011 2.35 0 .224.156.491.573.405a8.365 8.365 0 0 0 4.11-3.116 8.707 8.707 0 0 0 1.567-4.99c0-4.721-3.73-8.545-8.334-8.545Z" /></svg>
          </div>
          <h3 class="ecosystem-title">GitHub</h3>
          <p class="ecosystem-desc">Source code, issues, and contributions.</p>
        </a>
      </div>
    </div>
  </main>
  <SearchDialog />

  <footer slot="footer" class="home-footer">
    <div class="home-footer-inner">
      <div class="home-footer-links">
        <a href="https://launchfile.dev">Docs</a>
        <a href="https://launchfile.org">Specification</a>
        <a href="https://launchfile.io">Catalog</a>
        <a href="https://github.com/launchfile/launchfile">GitHub</a>
      </div>
      <p class="home-footer-license">Launchfile is open source under the <a href="https://github.com/launchfile/launchfile/blob/main/LICENSE">MIT license</a>.</p>
    </div>
  </footer>
</Base>

<script>
  // Mouse-tracking gradient on spec cards
  document.querySelectorAll('.spec-card').forEach((card) => {
    const el = card as HTMLElement;
    el.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      el.style.setProperty('--mouse-x', `${x}px`);
      el.style.setProperty('--mouse-y', `${y}px`);
    });
  });
</script>
