{
  "name": "launchfile-www-org",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "dev:search": "astro build && pagefind --site dist/client && cp -r dist/client/pagefind public/pagefind && astro dev",
    "build": "astro build && pagefind --site dist/client",
    "preview": "astro preview",
    "typecheck": "astro check",
    "publish": "bun run build && bunx wrangler pages deploy dist/client --project-name launchfile-org"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.1.7",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "6.1.4",
    "marked": "^17.0.6",
    "remark-breaks": "^4.0.0",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "pagefind": "^1.5.0",
    "typescript": "^6.0.0"
  }
}
