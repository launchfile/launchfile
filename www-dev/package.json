{
  "name": "launchfile-www-dev",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist/client",
    "dev:search": "astro build && pagefind --site dist/client && cp -r dist/client/pagefind public/pagefind && astro dev",
    "preview": "astro preview",
    "typecheck": "astro check",
    "publish": "bun run build && bunx wrangler pages deploy dist/client --project-name launchfile-dev"
  },
  "dependencies": {
    "@astrojs/cloudflare": "14.0.0",
    "@astrojs/markdown-satteri": "^0.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "7.0.0",
    "marked": "^18.0.2",
    "shiki": "^4.3.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^26.0.1",
    "pagefind": "^1.5.2",
    "typescript": "^6.0.3"
  }
}
